{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/mindbody/refs/heads/main/json-structure/public-api-v6-tip-structure.json",
  "name": "Tip",
  "description": "Implementation of the 'Tip' model.",
  "type": "object",
  "properties": {
    "StaffId": {
      "type": "int32",
      "description": "The ID of the staff member the tip is for.",
      "example": 123456
    },
    "SaleId": {
      "type": "int32",
      "description": "The sale\u2019s ID associated with the tip.",
      "example": 123456
    },
    "SaleDateTime": {
      "type": "datetime",
      "description": "The date and time when the tip was given.",
      "example": "2026-05-28T14:30:00Z"
    },
    "Earnings": {
      "type": "double",
      "description": "The amount tipped to the staff member.",
      "example": 1.0
    }
  }
}