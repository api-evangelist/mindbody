{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/mindbody/refs/heads/main/json-structure/public-api-v6-contact-log-comment-structure.json",
  "name": "ContactLogComment",
  "description": "Implementation of the 'ContactLogComment' model. A contact log comment.",
  "type": "object",
  "properties": {
    "Id": {
      "type": "int32",
      "description": "The comment\u2019s ID.",
      "example": 123456
    },
    "Text": {
      "type": "string",
      "description": "The comment\u2019s body text.",
      "example": "example-value"
    },
    "CreatedDateTime": {
      "type": "datetime",
      "description": "The local time when the comment was created.",
      "example": "2026-05-28T14:30:00Z"
    },
    "CreatedBy": {
      "$ref": "#/components/schemas/Staff",
      "description": "Information about the staff member who created the comment."
    }
  }
}