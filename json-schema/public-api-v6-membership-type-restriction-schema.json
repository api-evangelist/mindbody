{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/mindbody/refs/heads/main/json-schema/public-api-v6-membership-type-restriction-schema.json",
  "title": "MembershipTypeRestriction",
  "description": "Implementation of the 'MembershipTypeRestriction' model.",
  "type": "object",
  "properties": {
    "Id": {
      "type": "integer",
      "format": "int32",
      "description": "The ID of the membership that is allowed to purchase the contract.",
      "example": 123456
    },
    "Name": {
      "type": "string",
      "description": "The name of the membership type.",
      "example": "Sunset Yoga Studio"
    }
  }
}